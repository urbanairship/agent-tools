# Airship API Credentials
# Get these from go.airship.com > Settings > APIs & Integrations

# Region: "us" (default) or "eu"
AIRSHIP_REGION=us

# Bearer token (preferred)
# Use this for all standard API operations (push, channels, named users, etc.)
AIRSHIP_BEARER_TOKEN=your_bearer_token_here

# App key (required alongside bearer token for admin URL construction)
AIRSHIP_APP_KEY=your_app_key_here

# Master secret (only needed as a fallback if not using a bearer token,
# or for endpoints that explicitly require Basic Auth)
# AIRSHIP_MASTER_SECRET=your_master_secret_here

# Override the Go API base URL (optional — for staging, proxies, or custom routing)
# Does not affect Connect or Wallet URLs.
# AIRSHIP_API_URL=https://go.urbanairship.com
