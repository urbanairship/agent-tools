# Airship API Credentials
# Create OAuth credentials in the Airship dashboard: project Settings > OAuth
# Enable "Allow Basic Auth" when creating credentials to generate a Client Secret.

# Region: "us" (default) or "eu"
AIRSHIP_REGION=us

# App key (required as the OAuth token subject)
AIRSHIP_APP_KEY=your_app_key_here

# OAuth client credentials
AIRSHIP_CLIENT_ID=your_client_id_here
AIRSHIP_CLIENT_SECRET=your_client_secret_here

# Override the Go API base URL (optional - for staging, proxies, or custom routing)
# Does not affect Connect or Wallet URLs.
# AIRSHIP_API_URL=https://api.asnapius.com
