{
  "mcpServers": {
    "airship": {
      "command": "uv",
      "args": ["run", "--directory", "/PATH/TO/agent-tools", "airship-mcp"],
      "env": {
        "AIRSHIP_CLIENT_ID": "your_client_id",
        "AIRSHIP_CLIENT_SECRET": "your_client_secret",
        "AIRSHIP_APP_KEY": "your_app_key",
        "AIRSHIP_REGION": "us"
      }
    }
  }
}
