{
  "description": "Update field values and labels on a wallet pass",
  "request": {
    "method": "PUT",
    "url": "https://wallet-api.urbanairship.com/v1/pass/template/123/id/pass-abc-123",
    "headers": {
      "Api-Revision": "1.2",
      "Accept": "application/json",
      "Content-Type": "application/json",
      "Authorization": "Bearer <access_token>"
    },
    "body": {
      "fields": {
        "balance": {
          "value": "$150.00",
          "changeMessage": "Your balance has been updated to %@"
        },
        "memberName": {
          "value": "John Doe",
          "label": "Member"
        },
        "points": {
          "value": "2,500",
          "label": "Reward Points"
        }
      },
      "headers": {
        "primaryFields": {
          "value": "VIP Member",
          "changeMessage": "Your membership status has changed"
        }
      }
    }
  },
  "response": {
    "status": 200,
    "body": {
      "ticketId": 12345
    }
  }
}
