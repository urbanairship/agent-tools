{
  "description": "Update locations on a wallet pass (replaces all existing locations)",
  "request": {
    "method": "PUT",
    "url": "https://wallet-api.urbanairship.com/v1/pass/template/123/id/pass-abc-123",
    "headers": {
      "Api-Revision": "1.2",
      "Accept": "application/json",
      "Content-Type": "application/json",
      "Authorization": "Bearer <access_token>"
    },
    "body": {
      "locations": [
        {
          "latitude": 37.7749,
          "longitude": -122.4194,
          "relevantText": "Near San Francisco Store"
        },
        {
          "latitude": 34.0522,
          "longitude": -118.2437,
          "relevantText": "Near Los Angeles Store"
        }
      ]
    }
  },
  "response": {
    "status": 200,
    "body": {
      "ticketId": 12346
    }
  }
}
